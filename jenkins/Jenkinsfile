pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Pulling latest code from Gitea...'
                checkout scm
            }
        }

        stage('Test') {
            steps {
                echo 'Verifying project structure...'
                sh 'test -f portal/backend/app.py && echo "app.py found"'
                sh 'test -f portal/backend/requirements.txt && echo "requirements.txt found"'
                sh 'test -f portal/backend/Dockerfile && echo "Backend Dockerfile found"'
                sh 'test -f portal/frontend/index.html && echo "index.html found"'
                sh 'test -f portal/frontend/Dockerfile && echo "Frontend Dockerfile found"'
            }
        }

        stage('Build') {
            steps {
                echo 'Building Docker images...'
                sh 'docker build -t pulse-backend:latest portal/backend/'
                sh 'docker save pulse-backend:latest -o pulse-backend.tar'
                sh 'docker build -t pulse-frontend:latest portal/frontend/'
                sh 'docker save pulse-frontend:latest -o pulse-frontend.tar'
            }
        }

        stage('Deploy to Staging') {
            steps {
                echo 'Deploying to staging...'
                sh 'ansible-playbook -i ansible/inventory/staging.ini ansible/deploy.yml'
            }
        }

        stage('Approve Production') {
            steps {
                input message: 'Deploy to Production?', ok: 'Yes, deploy'
            }
        }

        stage('Deploy to Production') {
            steps {
                echo 'Deploying to production...'
                sh 'ansible-playbook -i ansible/inventory/production.ini ansible/deploy.yml'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}